# marketplace-core — local development environment
#
# Copy this file to `.env` and edit values as needed. The Makefile and
# docker-compose.yml auto-load `.env` (no `source` required).
#
#   cp .env.example .env
#
# NEVER commit .env — it may contain real credentials.

# ── Node runtime ─────────────────────────────────────────────────────
NODE_ENV=development

# ── Postgres (host port → container 5432) ────────────────────────────
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_dev
POSTGRES_DB=marketplace_core
POSTGRES_PORT=5432

# ── Meilisearch (host port → container 7700) ─────────────────────────
# Master key in dev is a literal; production MUST use a strong random secret.
MEILI_ENV=development
MEILI_MASTER_KEY=marketplace_dev_master_key
MEILI_PORT=7700

# ── gRPC server (exposed by #5 / PR-3) ───────────────────────────────
GRPC_PORT=50051

# ── Merchant schema ──────────────────────────────────────────────────
# URL (file:// or https://) to the JSON Schema that drives the storefront UI.
# Three demo schemas ship in PR-6 (#8) under schemas/.
MERCHANT_SCHEMA_URL=file:///schemas/vertivolatam/hortalizas.v1.json
