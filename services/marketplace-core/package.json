{
  "name": "@lapc506/marketplace-core",
  "version": "0.1.0",
  "description": "Production-ready TypeScript library for marketplace orchestration. Shopify-inspired API patterns for rental, retail, service, and P2P marketplaces.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./proto": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js"
    }
  },
  "files": [
    "dist/",
    "proto/",
    "appchain/",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "proto:gen": "grpc_tools_node_protoc --ts_out=src/generated --grpc_out=src/generated --plugin=protoc-gen-grpc=./node_modules/.bin/grpc_tools_node_protoc_plugin proto/marketplace_core.proto",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "marketplace",
    "grpc",
    "shopify",
    "storefront",
    "catalog",
    "inventory",
    "traceability",
    "supply-chain",
    "hexagonal-architecture",
    "ports-and-adapters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lapc506/marketplace-core.git"
  },
  "author": "Andrés (lapc506) <andres@dojocoding.io>",
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "meilisearch": "^0.57.0",
    "pg": "^8.20.0",
    "starknet": "^6.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "grpc_tools_node_protoc_ts": "^5.3.0",
    "grpc-tools": "^1.12.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
