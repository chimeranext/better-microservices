# vision-core — environment template. COPY to `.env` (gitignored) for local dev.
# NEVER put real secret values in this file or in git. Real values go to:
#   - GitHub Environment secrets (staging / production), or
#   - a local secret manager / the /secret-input flow.
# All vars use the VISION_ prefix (see src/vision_core/config.py).

# --- Deployment ---
VISION_TIER=cloud                 # cloud (Phase 1) | edge (Phase 2)

# --- Inference runtimes ---
# Self-hosted KServe URLs (leave blank to use hosted NIM endpoints below):
VISION_KSERVE_URL=
VISION_VLLM_URL=

# --- NVIDIA hosted NIM (build.nvidia.com) — server-side ONLY ---
# Fastest path to real inference with no local GPU. The KEY VALUE IS A SECRET —
# do NOT set it here. Set VISION_NVIDIA_API_KEY via env/secret per environment:
#   staging    -> NVIDIA key named "internal_staging"
#   production -> NVIDIA key named "public_prod" (backend-only despite the name)
VISION_NVIDIA_API_KEY=
VISION_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Object storage (MinIO/S3 via s3fs) — secrets, do not commit ---
VISION_MINIO_ENDPOINT=http://localhost:9000
VISION_MINIO_ACCESS_KEY=
VISION_MINIO_SECRET_KEY=

# --- Capture ingest ---
VISION_MQTT_BROKER_URL=mqtt://localhost:1883

# --- Behavior ---
VISION_LOW_CONFIDENCE_THRESHOLD=0.45
VISION_RETRAIN_AFTER_CORRECTIONS=50
