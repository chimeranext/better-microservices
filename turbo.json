{
  "$schema": "https://turbo.build/schema.json",
  "//": "SKELETON — the real pipeline is developed in sub-project #3 (Turborepo). This declares the task graph so the polyglot workspace is recognized.",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "typecheck": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
